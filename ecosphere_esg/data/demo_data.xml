<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Singleton dashboard record -->
    <record id="esg_dashboard_default" model="esg.dashboard">
        <field name="name">ESG Smart Dashboard</field>
    </record>

    <!-- Departments -->
    <record id="department_operations" model="esg.department">
        <field name="name">Operations</field>
        <field name="environmental_score">82</field>
        <field name="social_score">74</field>
        <field name="governance_score">88</field>
    </record>
    <record id="department_engineering" model="esg.department">
        <field name="name">Engineering</field>
        <field name="environmental_score">91</field>
        <field name="social_score">79</field>
        <field name="governance_score">85</field>
    </record>
    <record id="department_hr" model="esg.department">
        <field name="name">Human Resources</field>
        <field name="environmental_score">68</field>
        <field name="social_score">95</field>
        <field name="governance_score">80</field>
    </record>
    <record id="department_finance" model="esg.department">
        <field name="name">Finance</field>
        <field name="environmental_score">72</field>
        <field name="social_score">70</field>
        <field name="governance_score">92</field>
    </record>

    <!-- Emission Factors (if not already present) -->
    <record id="factor_fleet_fuel" model="esg.emission.factor">
        <field name="name">Fleet Fuel</field>
        <field name="carbon_value">2.31</field>
    </record>
    <record id="factor_manufacturing" model="esg.emission.factor">
        <field name="name">Manufacturing</field>
        <field name="carbon_value">0.85</field>
    </record>
    <record id="factor_electricity" model="esg.emission.factor">
        <field name="name">Electricity</field>
        <field name="carbon_value">0.42</field>
    </record>

    <!-- Carbon Transactions with dates for graph -->
    <record id="transaction_jan" model="esg.carbon.transaction">
        <field name="name">January Fleet Usage</field>
        <field name="transaction_date">2026-01-15</field>
        <field name="activity_amount">3200</field>
        <field name="emission_factor_id" ref="factor_fleet_fuel"/>
    </record>
    <record id="transaction_feb" model="esg.carbon.transaction">
        <field name="name">February Manufacturing</field>
        <field name="transaction_date">2026-02-10</field>
        <field name="activity_amount">15000</field>
        <field name="emission_factor_id" ref="factor_manufacturing"/>
    </record>
    <record id="transaction_mar" model="esg.carbon.transaction">
        <field name="name">March Electricity</field>
        <field name="transaction_date">2026-03-05</field>
        <field name="activity_amount">85000</field>
        <field name="emission_factor_id" ref="factor_electricity"/>
    </record>
    <record id="transaction_apr" model="esg.carbon.transaction">
        <field name="name">April Fleet Usage</field>
        <field name="transaction_date">2026-04-12</field>
        <field name="activity_amount">4100</field>
        <field name="emission_factor_id" ref="factor_fleet_fuel"/>
    </record>
    <record id="transaction_may" model="esg.carbon.transaction">
        <field name="name">May Manufacturing</field>
        <field name="transaction_date">2026-05-20</field>
        <field name="activity_amount">18200</field>
        <field name="emission_factor_id" ref="factor_manufacturing"/>
    </record>

    <!-- Assets -->
    <record id="asset_ev_fleet_1" model="esg.asset">
        <field name="name">EV Fleet Unit #1</field>
        <field name="department_id" ref="department_operations"/>
        <field name="state">allocated</field>
    </record>
    <record id="asset_solar_panel" model="esg.asset">
        <field name="name">Solar Panel Array</field>
        <field name="department_id" ref="department_engineering"/>
        <field name="state">available</field>
    </record>
    <record id="asset_carbon_sensor" model="esg.asset">
        <field name="name">Carbon Sensor Kit</field>
        <field name="department_id" ref="department_engineering"/>
        <field name="state">allocated</field>
    </record>
    <record id="asset_audit_toolkit" model="esg.asset">
        <field name="name">Compliance Audit Toolkit</field>
        <field name="department_id" ref="department_finance"/>
        <field name="state">available</field>
    </record>
    <record id="asset_training_kit" model="esg.asset">
        <field name="name">CSR Training Kit</field>
        <field name="department_id" ref="department_hr"/>
        <field name="state">available</field>
    </record>

    <!-- Bookings -->
    <record id="booking_ev_active" model="esg.asset.booking">
        <field name="name">Q2 Fleet Deployment</field>
        <field name="asset_id" ref="asset_ev_fleet_1"/>
        <field name="start_date">2026-04-01</field>
        <field name="end_date">2026-06-30</field>
        <field name="state">active</field>
    </record>
    <record id="booking_sensor_active" model="esg.asset.booking">
        <field name="name">Emissions Monitoring</field>
        <field name="asset_id" ref="asset_carbon_sensor"/>
        <field name="start_date">2026-03-15</field>
        <field name="end_date">2026-05-15</field>
        <field name="state">active</field>
    </record>
    <record id="booking_sensor_overdue" model="esg.asset.booking">
        <field name="name">Overdue Sensor Return</field>
        <field name="asset_id" ref="asset_carbon_sensor"/>
        <field name="start_date">2026-01-01</field>
        <field name="end_date">2026-02-28</field>
        <field name="state">overdue</field>
    </record>
    <record id="booking_audit_returned" model="esg.asset.booking">
        <field name="name">Q1 Audit Cycle</field>
        <field name="asset_id" ref="asset_audit_toolkit"/>
        <field name="start_date">2026-01-10</field>
        <field name="end_date">2026-03-10</field>
        <field name="state">returned</field>
    </record>

    <!-- ESG Categories -->
    <record id="category_carbon_reduction" model="esg.category">
        <field name="name">Carbon Reduction</field>
        <field name="description">Initiatives focused on lowering carbon footprint.</field>
    </record>
    <record id="category_csr_engagement" model="esg.category">
        <field name="name">CSR Engagement</field>
        <field name="description">Corporate social responsibility programs.</field>
    </record>
    <record id="category_compliance" model="esg.category">
        <field name="name">Regulatory Compliance</field>
        <field name="description">Governance and regulatory adherence.</field>
    </record>

    <!-- ESG Challenges -->
    <record id="challenge_green_commute" model="esg.challenge">
        <field name="name">30-Day Green Commute</field>
        <field name="department_id" ref="department_hr"/>
        <field name="category_id" ref="category_csr_engagement"/>
        <field name="module">social</field>
        <field name="start_date">2026-01-01</field>
        <field name="end_date">2026-03-31</field>
        <field name="status">active</field>
    </record>
    <record id="challenge_zero_waste" model="esg.challenge">
        <field name="name">Zero Waste Week</field>
        <field name="department_id" ref="department_operations"/>
        <field name="category_id" ref="category_carbon_reduction"/>
        <field name="module">environmental</field>
        <field name="start_date">2026-02-01</field>
        <field name="end_date">2026-02-28</field>
        <field name="status">completed</field>
    </record>
    <record id="challenge_audit_readiness" model="esg.challenge">
        <field name="name">ISO 14001 Audit Readiness</field>
        <field name="department_id" ref="department_finance"/>
        <field name="category_id" ref="category_compliance"/>
        <field name="module">governance</field>
        <field name="start_date">2026-03-01</field>
        <field name="end_date">2026-06-30</field>
        <field name="status">active</field>
        <field name="approval_state">submitted</field>
    </record>

    <!-- CSR Activities -->
    <record id="csr_volunteer_day" model="esg.csr.activity">
        <field name="name">Community Volunteer Day</field>
        <field name="employee_id" ref="base.user_admin"/>
        <field name="department_id" ref="department_hr"/>
        <field name="description">Annual team volunteer event at local shelter.</field>
        <field name="approval_state">submitted</field>
    </record>

    <!-- Employee Badges -->
    <record id="badge_eco_pioneer" model="esg.badge">
        <field name="name">Eco Pioneer</field>
        <field name="employee_id" ref="base.user_admin"/>
        <field name="description">Awarded for outstanding environmental contributions.</field>
        <field name="points">850</field>
        <field name="is_unlocked">False</field>
    </record>
    <record id="badge_compliance_champion" model="esg.badge">
        <field name="name">Compliance Champion</field>
        <field name="employee_id" ref="base.user_admin"/>
        <field name="description">Recognized for governance excellence.</field>
        <field name="points">720</field>
        <field name="is_unlocked">True</field>
        <field name="unlock_date">2026-02-01</field>
    </record>

    <!-- Policy Acknowledgements -->
    <record id="policy_code_of_conduct" model="esg.policy.acknowledgement">
        <field name="name">Code of Conduct 2026</field>
        <field name="employee_id" ref="base.user_admin"/>
        <field name="due_date">2026-01-31</field>
        <field name="acknowledged">False</field>
    </record>
    <record id="policy_sustainability" model="esg.policy.acknowledgement">
        <field name="name">Sustainability Policy</field>
        <field name="employee_id" ref="base.user_admin"/>
        <field name="due_date">2026-06-30</field>
        <field name="acknowledged">False</field>
    </record>

</odoo>
