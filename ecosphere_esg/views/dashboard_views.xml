<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Carbon Emissions Graph -->
    <record id="view_esg_carbon_transaction_graph" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.graph</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <graph string="Carbon Emissions Over Time" type="line" stacked="False">
                <field name="transaction_date" interval="month"/>
                <field name="total_emissions" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Carbon Transaction list: add date column -->
    <record id="view_esg_carbon_transaction_list_dashboard" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.list.dashboard</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="inherit_id" ref="view_esg_carbon_transaction_list"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="transaction_date"/>
            </field>
        </field>
    </record>

    <!-- Dashboard Kanban with responsive KPI cards -->
    <record id="view_esg_dashboard_kanban" model="ir.ui.view">
        <field name="name">esg.dashboard.kanban</field>
        <field name="model">esg.dashboard</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false" class="o_kanban_dashboard">
                <field name="assets_available"/>
                <field name="assets_allocated"/>
                <field name="active_bookings"/>
                <field name="overdue_returns"/>
                <field name="total_carbon_emissions"/>
                <templates>
                    <t t-name="card">
                        <div class="container-fluid p-2">
                            <h4 class="mb-3 text-primary fw-bold">ESG Smart Dashboard</h4>
                            <div class="row g-3">
                                <div class="col-12 col-md-6 col-lg-3">
                                    <div class="card border-success h-100 shadow-sm">
                                        <div class="card-body text-center">
                                            <div class="text-muted small text-uppercase fw-semibold">Assets Available</div>
                                            <h2 class="text-success mb-0 mt-2">
                                                <field name="assets_available"/>
                                            </h2>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-3">
                                    <div class="card border-primary h-100 shadow-sm">
                                        <div class="card-body text-center">
                                            <div class="text-muted small text-uppercase fw-semibold">Assets Allocated</div>
                                            <h2 class="text-primary mb-0 mt-2">
                                                <field name="assets_allocated"/>
                                            </h2>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-3">
                                    <div class="card border-info h-100 shadow-sm">
                                        <div class="card-body text-center">
                                            <div class="text-muted small text-uppercase fw-semibold">Active Bookings</div>
                                            <h2 class="text-info mb-0 mt-2">
                                                <field name="active_bookings"/>
                                            </h2>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-3">
                                    <div class="card border-danger h-100 shadow-sm">
                                        <div class="card-body text-center">
                                            <div class="text-muted small text-uppercase fw-semibold">Overdue Returns</div>
                                            <h2 class="text-danger mb-0 mt-2">
                                                <field name="overdue_returns"/>
                                            </h2>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-12">
                                    <div class="card border-secondary shadow-sm">
                                        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center">
                                            <span class="text-muted fw-semibold">Total Carbon Emissions (kg CO₂e)</span>
                                            <h3 class="text-secondary mb-0 mt-2">
                                                <field name="total_carbon_emissions"/>
                                            </h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Dashboard Form with responsive Bootstrap grid -->
    <record id="view_esg_dashboard_form" model="ir.ui.view">
        <field name="name">esg.dashboard.form</field>
        <field name="model">esg.dashboard</field>
        <field name="arch" type="xml">
            <form string="ESG Smart Dashboard" create="false" delete="false" edit="false">
                <sheet>
                    <div class="oe_title mb-3">
                        <h1>ESG Smart Dashboard</h1>
                    </div>
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-success h-100">
                                <div class="card-body text-center">
                                    <span class="text-muted d-block mb-2">Assets Available</span>
                                    <field name="assets_available" class="display-4 text-success" readonly="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-primary h-100">
                                <div class="card-body text-center">
                                    <span class="text-muted d-block mb-2">Assets Allocated</span>
                                    <field name="assets_allocated" class="display-4 text-primary" readonly="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-info h-100">
                                <div class="card-body text-center">
                                    <span class="text-muted d-block mb-2">Active Bookings</span>
                                    <field name="active_bookings" class="display-4 text-info" readonly="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-danger h-100">
                                <div class="card-body text-center">
                                    <span class="text-muted d-block mb-2">Overdue Returns</span>
                                    <field name="overdue_returns" class="display-4 text-danger" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12 col-md-6">
                            <group string="Emissions Summary">
                                <field name="total_carbon_emissions" readonly="1"/>
                            </group>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Asset views -->
    <record id="view_esg_asset_list" model="ir.ui.view">
        <field name="name">esg.asset.list</field>
        <field name="model">esg.asset</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-info="state == 'allocated'"/>
                <field name="active_booking_count"/>
            </list>
        </field>
    </record>

    <record id="view_esg_asset_form" model="ir.ui.view">
        <field name="name">esg.asset.form</field>
        <field name="model">esg.asset</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="row">
                        <div class="col-12 col-md-6">
                            <group>
                                <field name="name"/>
                                <field name="department_id"/>
                                <field name="state"/>
                            </group>
                        </div>
                        <div class="col-12 col-md-6">
                            <group>
                                <field name="active_booking_count"/>
                            </group>
                        </div>
                    </div>
                    <notebook>
                        <page string="Bookings">
                            <field name="booking_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Booking views -->
    <record id="view_esg_asset_booking_list" model="ir.ui.view">
        <field name="name">esg.asset.booking.list</field>
        <field name="model">esg.asset.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="department_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge" decoration-success="state == 'returned'" decoration-info="state == 'active'" decoration-danger="state == 'overdue'"/>
            </list>
        </field>
    </record>

    <record id="view_esg_asset_booking_form" model="ir.ui.view">
        <field name="name">esg.asset.booking.form</field>
        <field name="model">esg.asset.booking</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="row">
                        <div class="col-12 col-md-6">
                            <group>
                                <field name="name"/>
                                <field name="asset_id"/>
                                <field name="department_id"/>
                            </group>
                        </div>
                        <div class="col-12 col-md-6">
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="state"/>
                            </group>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Combined dashboard action -->
    <record id="action_esg_smart_dashboard" model="ir.actions.act_window">
        <field name="name">Smart Dashboard</field>
        <field name="res_model">esg.dashboard</field>
        <field name="view_mode">kanban,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_esg_carbon_emissions_graph" model="ir.actions.act_window">
        <field name="name">Carbon Emissions Over Time</field>
        <field name="res_model">esg.carbon.transaction</field>
        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="view_esg_carbon_transaction_graph"/>
    </record>

    <record id="action_esg_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">esg.asset</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_esg_asset_booking" model="ir.actions.act_window">
        <field name="name">Asset Bookings</field>
        <field name="res_model">esg.asset.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- OWL Client Action -->
    <record id="action_esg_dashboard_client" model="ir.actions.client">
        <field name="name">ESG Interactive Dashboard</field>
        <field name="tag">ecosphere_esg_dashboard</field>
    </record>

    <menuitem
        id="menu_esg_smart_dashboard"
        name="Smart Dashboard"
        parent="menu_ecosphere_root"
        action="action_esg_smart_dashboard"
        sequence="1"/>

    <menuitem
        id="menu_esg_carbon_graph"
        name="Emissions Analytics"
        parent="menu_ecosphere_root"
        action="action_esg_carbon_emissions_graph"
        sequence="15"/>

    <menuitem
        id="menu_esg_interactive_dashboard"
        name="Interactive Dashboard"
        parent="menu_ecosphere_root"
        action="action_esg_dashboard_client"
        sequence="2"/>

    <menuitem
        id="menu_esg_assets"
        name="Assets"
        parent="menu_ecosphere_root"
        action="action_esg_asset"
        sequence="40"/>

    <menuitem
        id="menu_esg_asset_bookings"
        name="Asset Bookings"
        parent="menu_ecosphere_root"
        action="action_esg_asset_booking"
        sequence="45"/>

</odoo>
