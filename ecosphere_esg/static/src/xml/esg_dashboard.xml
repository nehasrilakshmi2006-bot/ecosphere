<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ecosphere_esg.EsgDashboard">
        <div class="o_esg_dashboard h-100 overflow-auto bg-view">
            <div class="container-fluid py-4">
                <div class="row mb-4">
                    <div class="col-12">
                        <h2 class="fw-bold text-primary mb-1">EcoSphere ESG Dashboard</h2>
                        <p class="text-muted mb-0">Real-time sustainability KPIs · Mobile-responsive</p>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="text-center py-5">
                        <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                        <p class="text-muted mt-2">Loading dashboard data…</p>
                    </div>
                </t>

                <t t-else="">
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-success h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase fw-semibold">Assets Available</div>
                                    <h2 class="text-success mb-0 mt-2" t-esc="state.kpis.assets_available"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-primary h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase fw-semibold">Assets Allocated</div>
                                    <h2 class="text-primary mb-0 mt-2" t-esc="state.kpis.assets_allocated"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-info h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase fw-semibold">Active Bookings</div>
                                    <h2 class="text-info mb-0 mt-2" t-esc="state.kpis.active_bookings"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card border-danger h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase fw-semibold">Overdue Returns</div>
                                    <h2 class="text-danger mb-0 mt-2" t-esc="state.kpis.overdue_returns"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">Total Carbon Emissions</h5>
                                    <h3 class="text-secondary">
                                        <t t-esc="formattedEmissions"/> kg CO₂e
                                    </h3>
                                    <button class="btn btn-outline-primary btn-sm mt-2" t-on-click="openEmissionsGraph">
                                        <i class="fa fa-line-chart me-1"/> View Emissions Chart
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">Department Rankings</h5>
                                    <p class="text-muted">Compare ESG performance across departments.</p>
                                    <button class="btn btn-outline-success btn-sm mt-2" t-on-click="openDepartmentRankings">
                                        <i class="fa fa-trophy me-1"/> View Leaderboard
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
